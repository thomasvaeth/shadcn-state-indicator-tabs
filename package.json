{
  "name": "@thomasvaeth/state-indicator-tabs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm registry:build && next dev",
    "build": "pnpm registry:build && next build",
    "start": "next start",
    "registry:build": "shadcn build",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-tabs": "^1.1.13",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "next": "^16.1.6",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwind-merge": "^3.3.0"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.11",
    "@types/react-dom": "^19.1.7",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "shadcn": "^4.0.6",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.9.2"
  },
  "lint-staged": {
    "*.{js,jsx,mjs,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,json,md,html,yml,yaml}": "prettier --write"
  }
}
